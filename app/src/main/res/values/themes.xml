<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Aegis" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Fondo negro de la app — elimina el flash blanco al arrancar -->
        <item name="android:windowBackground">@color/backgroundBlackgrey</item>
        <item name="android:statusBarColor">@color/backgroundBlackgrey</item>
        <item name="android:navigationBarColor">@color/backgroundBlackgrey</item>
        <!-- Android 12+ splash screen -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/backgroundBlackgrey</item>
    </style>
</resources>
